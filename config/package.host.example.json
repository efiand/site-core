{
	"dependencies": {
		"site-core": "github:efiand/site-core#1.1.8"
	},
	"pre-commit": ["lint-format", "test"],
	"scripts": {
		"lint-format": "site-core-lint --write",
		"postinstall": "site-core-postinstall",
		"test": "site-core-run node --import site-core/tools/register-vendors.js --test --test-isolation=process \"test/**/*.spec.js\""
	}
}
